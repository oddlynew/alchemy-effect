{
  "name": "@oddlynew/alchemy-monorepo",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/oddlynew/alchemy-effect"
  },
  "type": "module",
  "packageManager": "bun@1.3.13",
  "module": "./lib/index.js",
  "scripts": {
    "audit:service": "bun scripts/audit-service.ts",
    "build:packages": "bun nx run-many -t build --projects=@oddlynew/alchemy,@oddlynew/alchemy-better-auth,@oddlynew/alchemy-pr-package --parallel=6",
    "build": "bun nx run-many -t build --projects=@oddlynew/alchemy-website,@oddlynew/alchemy,@oddlynew/alchemy-better-auth,@oddlynew/alchemy-pr-package --parallel=6",
    "clean": "git clean -fqdx -e .env -e '.env.*'",
    "clear:state": "alchemy state clear ./projects/alchemy/apps/nuke/alchemy.run.ts",
    "download:env": "doppler secrets download --project ${DOPPLER_PROJECT:-alchemy-effect-fork} --config ${DOPPLER_CONFIG:-dev} --no-file --format env > .env",
    "download:env:prd": "doppler secrets download --project ${DOPPLER_PROJECT:-alchemy-effect-fork} --config ${DOPPLER_CONFIG:-prd} --no-file --format env > .env.prd",
    "format:check": "oxfmt --check .",
    "format": "oxfmt .",
    "nuke": "bash scripts/nuke.sh",
    "opencode": "OPENCODE_EXPERIMENTAL_OXFMT=true opencode",
    "prepare": "husky",
    "setup": "effect-language-service patch && bun download:env",
    "sync:submodules": "git submodule sync --recursive && git submodule update --init --recursive",
    "test:benchmark": "bun run --filter @oddlynew/alchemy test:benchmark",
    "test:canary": "SMOKE_CANARY=1 bun test --only-failures ./test/smoke.test.ts",
    "test:examples": "bun run --filter ./projects/alchemy/examples/cloudflare-worker --filter ./projects/alchemy/examples/cloudflare-worker-auth --filter ./projects/alchemy/examples/cloudflare-worker-async --filter ./projects/alchemy/examples/cloudflare-tanstack --filter ./projects/alchemy/examples/cloudflare-tanstack-start-solid --filter ./projects/alchemy/examples/aws-lambda test && bun format",
    "test:fast": "NO_SLOW_TESTS=1 FAST=1 bun run test:live",
    "test:live": "bun nx test @oddlynew/alchemy",
    "test:smoke": "bun test --only-failures ./test/smoke.test.ts",
    "test": "bun run test:live"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "projects/alchemy/apps/*",
      "projects/alchemy/packages/*",
      "projects/alchemy/examples/*",
      "projects/alchemy/examples/monorepo-single-stack/*",
      "projects/alchemy/examples/monorepo-multi-stack/*",
