{
  "name": "@oddlynew/alchemy-nx-r2-cache-worker",
  "version": "0.0.0",
  "private": true,
  "description": "Self-hosted Nx remote cache Worker backed by Cloudflare R2",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "workerd": {
        "module": "./dist/index.js",
        "import": "./dist/index.js"
      },
      "node": {
        "module": "./dist/index.js",
        "import": "./dist/index.js"
      },
      "browser": null,
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@effect/vitest": "catalog:",
    "@oddlynew/alchemy-oxlint-config": "workspace:*",
    "@oddlynew/alchemy-typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@oddlynew/alchemy": "workspace:*",
    "effect": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  },
  "nx": {
    "name": "nx-r2-cache-worker",
    "doppler": {
      "project": "alchemy-effect-fork"
    },
    "alchemy": {
      "deploy": {
        "dopplerConfig": "prd",
        "fixedStage": "prod"
      },
      "destroy": {
        "dopplerConfig": "prd",
        "fixedStage": "prod"
      },
      "plan": {
        "dopplerConfig": "prd",
        "fixedStage": "prod"
      }
    },
    "tags": [
      "type:app",
      "scope:alchemy",
      "domain:nx",
      "test:ci"
    ]
  }
}
