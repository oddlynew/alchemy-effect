{
  "extends": "@alchemy.run/typescript-config/node.json",
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "lib": ["ES2024", "WebWorker"],
    "types": ["@cloudflare/workers-types", "bun"],
    "outDir": ".tsbuild/dev"
  },
  "include": [
    "alchemy.run.ts",
    "tsdown.config.ts",
    "vitest.config.ts",
    "src/**/*.ts"
  ],
  "exclude": ["src/**/*.test.ts", "src/**/__tests__/**/*.ts"]
}
