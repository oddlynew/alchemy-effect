{
  "name": "@alchemy.run/nx-alchemy-plugin",
  "version": "0.0.0",
  "private": true,
  "description": "Nx plugin that infers deployment targets for packages with alchemy.run.ts files.",
  "keywords": [
    "alchemy",
    "deployment",
    "nx",
    "plugin"
  ],
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "prepare": "tsdown"
  },
  "devDependencies": {
    "@nx/devkit": "catalog:",
    "@alchemy.run/oxlint-config": "workspace:*",
    "@alchemy.run/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@nx/devkit": "catalog:"
  },
  "nx": {
    "name": "nx-alchemy-plugin",
    "tags": [
      "type:tooling",
      "scope:repo"
    ]
  }
}
