{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "tui": {
    "enabled": true,
    "autoExit": true
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "{workspaceRoot}/bun.lock"],
    "taskSources": [
      "default",
      "!{projectRoot}/**/*.md",
      "!{projectRoot}/docs/**",
      "!{projectRoot}/README.md"
    ],
    "production": [
      "taskSources",
      "!{projectRoot}/**/*.spec.*",
      "!{projectRoot}/**/*.test.*",
      "!{projectRoot}/**/__tests__/**",
      "!{projectRoot}/test/**",
      "!{projectRoot}/vitest.config.*",
      "!{projectRoot}/playwright.config.*"
    ]
  },
  "pluginsConfig": {
    "@nx/js": {
      "projectsAffectedByDependencyUpdates": "all"
    }
  },
  "release": {
    "groups": {
      "alchemy": {
        "projects": [
          "@oddlynew/alchemy",
          "@oddlynew/alchemy-better-auth",
          "@oddlynew/alchemy-pr-package"
        ],
        "projectsRelationship": "fixed",
        "releaseTag": {
          "pattern": "@oddlynew/alchemy@{version}"
        }
      },
      "alchemy-node-utils": {
        "projects": ["@oddlynew/alchemy-node-utils"],
        "projectsRelationship": "fixed",
        "releaseTag": {
          "pattern": "@oddlynew/alchemy-node-utils@{version}"
        }
      },
      "distilled": {
        "projects": [
          "@oddlynew/distilled-aws",
          "@oddlynew/distilled-axiom",
          "@oddlynew/distilled-azure",
          "@oddlynew/distilled-cloudflare",
          "@oddlynew/distilled-coinbase",
          "@oddlynew/distilled-core",
          "@oddlynew/distilled-expo-eas",
          "@oddlynew/distilled-fly-io",
          "@oddlynew/distilled-gcp",
          "@oddlynew/distilled-kubernetes",
          "@oddlynew/distilled-mongodb-atlas",
          "@oddlynew/distilled-neon",
          "@oddlynew/distilled-planetscale",
          "@oddlynew/distilled-posthog",
          "@oddlynew/distilled-prisma-postgres",
          "@oddlynew/distilled-stripe",
          "@oddlynew/distilled-supabase",
          "@oddlynew/distilled-turso",
          "@oddlynew/distilled-typesense",
          "@oddlynew/distilled-workos"
        ],
        "projectsRelationship": "fixed",
        "releaseTag": {
          "pattern": "@oddlynew/distilled@{version}"
        }
      },
      "cloudflare-tools": {
        "projects": [
          "@oddlynew/distilled-cloudflare-rolldown-plugin",
          "@oddlynew/distilled-cloudflare-runtime",
          "@oddlynew/distilled-cloudflare-vite-plugin"
        ],
        "projectsRelationship": "fixed",
        "releaseTag": {
          "pattern": "@oddlynew/cloudflare-tools@{version}"
        }
      }
    },
    "conventionalCommits": {
      "useCommitScope": false
    },
    "version": {
      "conventionalCommits": true,
      "fallbackCurrentVersionResolver": "disk",
      "updateDependents": "never"
    },
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": {
        "createRelease": false,
        "renderOptions": {
          "authors": true,
          "commitReferences": true,
          "versionTitleDate": true
        }
      }
    }
  },
  "parallel": 6,
  "targetDefaults": [
    {
      "target": "build",
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"],
      "outputs": [
        "{projectRoot}/lib",
        "{projectRoot}/dist",
        "{projectRoot}/.cache",
        "{projectRoot}/.tsbuild",
        "{projectRoot}/tsconfig.tsbuildinfo"
      ],
      "cache": true
    },
    {
      "target": "typecheck",
      "dependsOn": ["^build", "^typecheck"],
      "inputs": ["taskSources", "^production"],
      "outputs": [
        "{projectRoot}/.cache",
        "{projectRoot}/.tsbuild",
        "{projectRoot}/tsconfig.tsbuildinfo"
      ],
      "cache": true
    },
    {
      "target": "test",
      "dependsOn": ["build", "^build"],
      "inputs": [
        "taskSources",
        "^production",
        {
          "env": "CI"
        }
      ],
      "outputs": [],
      "cache": true
    },
    {
      "target": "lint",
      "dependsOn": ["^build"],
      "inputs": [
        "taskSources",
        "^production",
        "{workspaceRoot}/oxlint.config.ts",
        "{workspaceRoot}/projects/distilled/oxlint.config.ts",
        "{workspaceRoot}/projects/cloudflare-tools/oxlint.config.ts"
      ],
      "outputs": [],
      "cache": true
    },
    {
      "target": "dev",
      "cache": false,
      "continuous": true,
      "dependsOn": ["^build"]
    },
    {
      "target": "deploy",
      "cache": false,
      "dependsOn": ["build"]
    },
    {
      "target": "nx-release-publish",
      "cache": false,
      "dependsOn": ["build", "^build"]
    },
    {
      "target": "destroy",
      "cache": false
    },
    {
      "target": "plan",
      "cache": false
    }
  ],
  "plugins": [
    {
      "plugin": "@oddlynew/alchemy-nx-tsdown-plugin",
      "exclude": [
        ".vendor/**",
        "projects/cloudflare-tools/workers-sdk/**",
        "projects/distilled/packages/*/specs/**"
      ],
      "options": {
        "buildTargetName": "build"
      }
    },
    {
      "plugin": "@oddlynew/alchemy-nx-tsgo-plugin",
      "exclude": [
        ".vendor/**",
        "projects/alchemy/apps/website/**",
        "projects/alchemy/examples/**",
        "projects/cloudflare-tools/fixtures/**",
        "projects/cloudflare-tools/workers-sdk/**",
        "projects/distilled/packages/*/specs/**"
      ],
      "options": {
        "typecheckTargetName": "typecheck"
      }
    },
    {
      "plugin": "@nx/vitest",
      "exclude": [
        ".vendor/**",
        "projects/alchemy/examples/**",
        "projects/cloudflare-tools/fixtures/**",
        "projects/cloudflare-tools/workers-sdk/**",
        "projects/distilled/packages/*/specs/**"
      ],
      "options": {
        "testTargetName": "test",
        "testMode": "run"
      }
    },
    {
      "plugin": "@oddlynew/alchemy-nx-alchemy-plugin",
      "exclude": [
        ".vendor/**",
        "projects/cloudflare-tools/workers-sdk/**",
        "projects/distilled/packages/*/specs/**"
      ],
      "options": {
        "devTargetName": "dev",
        "deployTargetName": "deploy",
        "destroyTargetName": "destroy",
        "planTargetName": "plan"
      }
    },
    {
      "plugin": "@oddlynew/alchemy-nx-oxlint-plugin",
      "exclude": [
        ".vendor/**",
        "projects/cloudflare-tools/packages/vendor/**",
        "projects/cloudflare-tools/workers-sdk/**",
        "projects/distilled/packages/*/specs/**"
      ],
      "options": {
        "lintTargetName": "lint",
        "typeAware": true
      }
    }
  ],
  "neverConnectToCloud": true,
  "analytics": false
}
