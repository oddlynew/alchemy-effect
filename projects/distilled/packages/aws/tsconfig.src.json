{
  "extends": "@oddlynew/alchemy-typescript-config/node.json",
  "compilerOptions": {
    "resolveJsonModule": true,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "isolatedDeclarations": false,
    "outDir": ".tsbuild/src",
    "rootDir": "src",
    "tsBuildInfoFile": ".tsbuild/src.tsbuildinfo"
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**/*.ts",
    "**/__tests__/**/*.tsx",
    "test/**",
    "tests/**"
  ]
}
