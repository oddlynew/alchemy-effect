{
  "name": "@oddlynew/distilled-coinbase",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsgo -b tsconfig.build.json --noCheck --checkers 1 --builders 1",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/lib", "{projectRoot}/.tsbuild"],
      "cache": true,
      "dependsOn": ["^build"],
      "parallelism": false
    }
  }
}
