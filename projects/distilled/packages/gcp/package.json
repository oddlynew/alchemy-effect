{
  "name": "@oddlynew/distilled-gcp",
  "version": "0.26.1",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/oddlynew/alchemy-effect",
    "directory": "projects/distilled/packages/gcp"
  },
  "files": [
    "lib",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./*": {
      "types": "./lib/services/*.d.ts",
      "bun": "./src/services/*.ts",
      "default": "./lib/services/*.js"
    },
    "./unstable/*": {
      "types": "./lib/unstable-services/*.d.ts",
      "bun": "./src/unstable-services/*.ts",
      "default": "./lib/unstable-services/*.js"
    },
    "./Category": {
      "types": "./lib/category.d.ts",
      "bun": "./src/category.ts",
      "default": "./lib/category.js"
    },
    "./Errors": {
      "types": "./lib/errors.d.ts",
      "bun": "./src/errors.ts",
      "default": "./lib/errors.js"
    },
    "./Retry": {
      "types": "./lib/retry.d.ts",
      "bun": "./src/retry.ts",
      "default": "./lib/retry.js"
    },
    "./Traits": {
      "types": "./lib/traits.d.ts",
      "bun": "./src/traits.ts",
      "default": "./lib/traits.js"
    },
    ".": {
      "types": "./lib/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./lib/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun ../../scripts/build-generated-package.ts .",
    "fmt": "oxfmt --write src",
    "generate": "bun run scripts/generate.ts && oxlint --fix src && oxfmt --write src && oxfmt --write src",
    "specs:fetch": "git submodule update --force --init --recursive --depth=1 specs/distilled-spec-gcp && git -C specs/distilled-spec-gcp checkout -- .",
    "specs:update": "git -C specs/distilled-spec-gcp fetch && git -C specs/distilled-spec-gcp checkout main && git -C specs/distilled-spec-gcp pull"
  },
  "dependencies": {
    "@oddlynew/distilled-core": "workspace:*"
  },
  "devDependencies": {
    "@oddlynew/alchemy-typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
