{
  "name": "@oddlynew/distilled-gcp",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bun ../../scripts/build-generated-package.ts .",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/lib"],
      "cache": true,
      "dependsOn": ["^build"],
      "parallelism": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "oxlint src",
        "cwd": "{projectRoot}"
      },
      "outputs": [],
      "cache": true,
      "dependsOn": ["^build"],
      "parallelism": false
    }
  }
}
