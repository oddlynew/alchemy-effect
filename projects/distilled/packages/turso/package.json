{
  "name": "@oddlynew/distilled-turso",
  "version": "0.26.2",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/oddlynew/alchemy-effect",
    "directory": "projects/distilled/packages/turso"
  },
  "files": [
    "lib",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "bun": "./src/index.ts",
      "default": "./lib/index.js"
    },
    "./Category": {
      "types": "./lib/category.d.ts",
      "bun": "./src/category.ts",
      "default": "./lib/category.js"
    },
    "./Client": {
      "types": "./lib/client.d.ts",
      "bun": "./src/client.ts",
      "default": "./lib/client.js"
    },
    "./Credentials": {
      "types": "./lib/credentials.d.ts",
      "bun": "./src/credentials.ts",
      "default": "./lib/credentials.js"
    },
    "./Errors": {
      "types": "./lib/errors.d.ts",
      "bun": "./src/errors.ts",
      "default": "./lib/errors.js"
    },
    "./Operations": {
      "types": "./lib/operations/index.d.ts",
      "bun": "./src/operations/index.ts",
      "default": "./lib/operations/index.js"
    },
    "./Retry": {
      "types": "./lib/retry.d.ts",
      "bun": "./src/retry.ts",
      "default": "./lib/retry.js"
    },
    "./Sensitive": {
      "types": "./lib/sensitive.d.ts",
      "bun": "./src/sensitive.ts",
      "default": "./lib/sensitive.js"
    },
    "./Traits": {
      "types": "./lib/traits.d.ts",
      "bun": "./src/traits.ts",
      "default": "./lib/traits.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsgo -b tsconfig.build.json --noCheck",
    "fmt": "oxfmt --write src",
    "nuke": "bun scripts/nuke.ts",
    "generate": "bun run scripts/generate.ts && oxlint --fix src && oxfmt --write src && oxfmt --write src",
    "specs:fetch": "git submodule update --force --init --recursive --depth=1 specs/turso-docs && git -C specs/turso-docs checkout -- .",
    "specs:update": "git -C specs/turso-docs fetch && git -C specs/turso-docs checkout main && git -C specs/turso-docs pull"
  },
  "dependencies": {
    "@oddlynew/distilled-core": "workspace:*"
  },
  "devDependencies": {
    "@oddlynew/alchemy-typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:"
  }
}
