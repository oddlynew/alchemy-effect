{
  "name": "distilled",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --filter '@distilled.cloud/core' build && bun --filter '*' build",
    "typecheck": "bun --filter '*' typecheck",
    "fmt": "bun --filter '*' fmt",
    "lint": "bun --filter '*' lint",
    "check": "bun --filter '*' check",
    "test": "bun --filter '*' test",
    "generate": "bun --filter '*' generate",
    "specs:fetch": "bun --filter '*' specs:fetch",
    "specs:update": "bun --filter '*' specs:update",
    "bump": "bun ./scripts/bump.ts",
    "publish:npm": "bun run --filter '@distilled.cloud/core' publish:npm && bun run --filter '*' publish:npm"
  },
  "workspaces": {
    "packages": [
      "./packages/*"
    ],
    "catalog": {
      "@aws-crypto/crc32": "^5.2.0",
      "@aws-crypto/util": "^5.2.0",
      "@aws-sdk/credential-providers": "^3.994.0",
      "@aws-sdk/types": "^3.973.1",
      "@effect/platform-bun": "4.0.0-beta.25",
      "@effect/platform-node": "4.0.0-beta.25",
      "@effect/vitest": "4.0.0-beta.25",
      "@smithy/shared-ini-file-loader": "^4.4.3",
      "@smithy/types": "^4.12.0",
      "@smithy/util-base64": "^4.3.0",
      "@types/bun": "^1.3.0",
      "@types/node": "^25.3.5",
      "@typescript/native-preview": "^7.0.0-dev.20260124.1",
      "archiver": "^7.0.1",
      "aws4fetch": "^1.0.20",
      "dedent": "^1.7.0",
      "dotenv": "^16.5.0",
      "effect": "4.0.0-beta.25",
      "fast-xml-parser": "^5.3.2",
      "oxfmt": "^0.36.0",
      "oxlint": "^1.51.0",
      "pathe": "^2.0.3",
      "vite": "^7.3.1",
      "vitest": "^3.2.3",
      "yaml": "^2.7.1"
    }
  },
  "devDependencies": {
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "changelogithub": "^14.0.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "yaml": "catalog:"
  }
}
