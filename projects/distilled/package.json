{
  "name": "@oddlynew/distilled",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun --filter '@oddlynew/distilled-core' build && bun --filter '@oddlynew/distilled-*' --filter '!@oddlynew/distilled-website' build",
    "build:clean": "bun install:clean && bun run build",
    "clean": "git clean -fqdx . -e .env",
    "install:clean": "bun clean && bun install",
    "download:env": "doppler secrets download --no-file --format env > .env",
    "typecheck": "bun --filter '@oddlynew/distilled-*' --filter '!@oddlynew/distilled-website' typecheck",
    "fmt": "bun --filter '@oddlynew/distilled-*' --filter '!@oddlynew/distilled-website' fmt",
    "lint": "bun --filter '@oddlynew/distilled-*' --filter '!@oddlynew/distilled-website' lint",
    "flint": "bun run fmt && bun run lint",
    "check": "bun --filter '@oddlynew/distilled-*' --filter '!@oddlynew/distilled-website' check",
    "test": "bun --filter '@oddlynew/distilled-*' --filter '!@oddlynew/distilled-website' test",
    "generate": "bun --filter '@oddlynew/distilled-*' --filter '!@oddlynew/distilled-website' generate",
    "specs:fetch": "bun --filter '@oddlynew/distilled-*' --filter '!@oddlynew/distilled-website' specs:fetch",
    "specs:update": "bun --filter '@oddlynew/distilled-*' --filter '!@oddlynew/distilled-website' specs:update",
    "create-sdk": "bun ./scripts/create-sdk.ts",
    "nuke": "bun --filter '@oddlynew/distilled-*' --filter '!@oddlynew/distilled-website' nuke",
    "generate-nuke": "bun ./scripts/generate-nuke.ts",
    "generate-tests": "bun ./scripts/generate-tests.ts",
    "error-discovery": "bun ./scripts/error-discovery.ts"
  },
  "dependencies": {
    "@effect/platform-bun": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.81",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "aws4fetch": "^1.0.20",
    "changelogithub": "^14.0.0",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "yaml": "catalog:"
  },
  "overrides": {
    "undici": "7.10.0"
  }
}
