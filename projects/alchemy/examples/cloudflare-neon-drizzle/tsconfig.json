{
  "extends": "@alchemy.run/typescript-config/bun.json",
  "include": [
    "alchemy.run.ts",
    "src/**/*.ts",
    "scripts/**/*.ts",
    "test/**/*.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "rootDir": ".",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "target": "ESNext"
  },
  "references": [
    {
      "path": "../../packages/alchemy/tsconfig.json"
    }
  ]
}
