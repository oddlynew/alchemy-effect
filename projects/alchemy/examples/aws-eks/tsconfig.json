{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "include": ["alchemy.run.ts"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "rootDir": "../..",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "paths": {
      "@oddlynew/alchemy": ["../../packages/alchemy/src/index.ts"],
      "@oddlynew/alchemy/*": ["../../packages/alchemy/src/*"]
    }
  },
  "references": [
    {
      "path": "../../packages/alchemy/tsconfig.src.json"
    }
  ]
}
