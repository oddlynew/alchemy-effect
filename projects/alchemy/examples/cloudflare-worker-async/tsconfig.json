{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "include": ["alchemy.run.ts", "src/**/*.ts", "test/**/*.ts"],
  "compilerOptions": {
    "composite": true,
    "noEmit": true,
    "rootDir": ".",
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "types": ["bun", "@cloudflare/workers-types"]
  },
  "references": [
    {
      "path": "../../packages/alchemy/tsconfig.src.json"
    },
    {
      "path": "../../packages/better-auth/tsconfig.src.json"
    }
  ]
}
