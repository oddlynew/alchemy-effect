{
  "include": [
    "alchemy.run.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "vite.config.ts"
  ],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "composite": true,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "types": ["vite/client", "react"]
  }
}
