{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "include": ["package.json", "test"],
  "exclude": [
    "test/Local/fixtures/rpc-server-entry.ts",
    "test/Local/fixtures/rpc-spawner-parent.ts"
  ],
  "compilerOptions": {
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/solid",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "composite": true,
    "outDir": ".tsbuild/test",
    "rootDir": ".",
    "isolatedDeclarations": false,
    "tsBuildInfoFile": ".tsbuild/test.tsbuildinfo"
  },
  "references": [
    {
      "path": "./tsconfig.src.json"
    },
    {
      "path": "./tsconfig.bin.json"
    }
  ]
}
