{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "paths": {
      "@/*": ["./src/*"]
    },
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "target": "ESNext",
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/solid",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "isolatedDeclarations": false,
    "outDir": ".tsbuild/src",
    "rootDir": ".",
    "tsBuildInfoFile": ".tsbuild/src.tsbuildinfo"
  },
  "include": ["package.json", "src/**/*.ts", "src/**/*.tsx", "src/**/*.json"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**/*.ts",
    "**/__tests__/**/*.tsx",
    "test/**",
    "tests/**"
  ]
}
