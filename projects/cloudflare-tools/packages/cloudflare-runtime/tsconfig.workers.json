{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "include": ["src/**/*.worker.ts", "src/**/*.shared.ts"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": ".tsbuild/workers.tsbuildinfo",
    "outDir": ".tsbuild/workers",
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "types": ["@cloudflare/workers-types/experimental", "node"],
    "declaration": true,
    "declarationMap": true,
    "isolatedDeclarations": false
  }
}
