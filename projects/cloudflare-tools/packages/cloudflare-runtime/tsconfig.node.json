{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "include": ["src"],
  "exclude": ["src/internal/workers.d.ts", "src/**/*.worker.ts"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": ".tsbuild/node.tsbuildinfo",
    "outDir": ".tsbuild/node",
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedDeclarations": false
  }
}
