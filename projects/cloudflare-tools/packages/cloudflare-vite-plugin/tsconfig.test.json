{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "include": ["test"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": ".tsbuild/test.tsbuildinfo",
    "outDir": ".tsbuild/test",
    "types": ["node"],
    "paths": {
      "#/*": ["./src/*"]
    },
    "rootDir": ".",
    "isolatedDeclarations": false
  },
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
