{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "include": ["src"],
  "exclude": ["dist", "**/*.worker.ts"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": ".tsbuild/node.tsbuildinfo",
    "outDir": ".tsbuild/node",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "isolatedDeclarations": false
  }
}
