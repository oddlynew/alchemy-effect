  "dependencies": {
    "@distilled.cloud/cloudflare-rolldown-plugin": "workspace:*"
  },
  "devDependencies": {
    "@alchemy.run/typescript-config": "workspace:*",
    "@cloudflare/workers-types": "catalog:workers",
    "@distilled.cloud/build-utils": "workspace:*",
    "@distilled.cloud/vendor-workers-shared": "workspace:*",
    "@effect/platform-node": "catalog:effect",
    "@types/ws": "^8.18.1",
    "rolldown": "catalog:",
    "tsdown": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "ws": "^8.21.0"
  },
  "peerDependencies": {
    "@distilled.cloud/cloudflare": "catalog:",
    "@distilled.cloud/cloudflare-runtime": "workspace:*",
