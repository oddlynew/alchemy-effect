  "repository": {
    "type": "git",
    "url": "git+https://github.com/alchemy-run/cloudflare-tools.git",
    "directory": "projects/cloudflare-tools/packages/cloudflare-vite-plugin"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/node/plugin.mjs",
  "types": "./dist/node/plugin.d.mts",
