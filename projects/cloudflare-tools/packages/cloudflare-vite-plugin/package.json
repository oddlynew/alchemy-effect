{
  "name": "@distilled.cloud/cloudflare-vite-plugin",
  "version": "0.1.0",
  "homepage": "https://github.com/alchemy-run/cloudflare-tools/tree/main/packages/cloudflare-vite-plugin#readme",
  "bugs": {
    "url": "https://github.com/alchemy-run/cloudflare-tools/issues"
  },
  "license": "MIT",
  "author": {
    "name": "John Royal",
    "email": "john@alchemy.run",
    "url": "https://distilled.cloud"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alchemy-run/cloudflare-tools.git",
    "directory": "packages/cloudflare-vite-plugin"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/plugin.js",
  "types": "./dist/plugin.d.ts",
  "exports": {
    ".": {
      "bun": "./src/plugin.ts",
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsc --watch",
    "build": "tsc",
    "build:clean": "rm -rf dist && bun run build",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "prepublishOnly": "bun run build:clean",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@distilled.cloud/cloudflare-rolldown-plugin": "workspace:*"
  },
  "devDependencies": {
    "rolldown": "^1.0.0-rc.13",
    "vite": "^8.0.3",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  }
}
