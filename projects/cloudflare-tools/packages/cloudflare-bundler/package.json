{
  "name": "@distilled.cloud/cloudflare-bundler",
  "version": "0.1.7",
  "description": "Effect-native bundler for Cloudflare Workers.",
  "keywords": [
    "bundler",
    "cloudflare",
    "effect",
    "esbuild",
    "workers"
  ],
  "homepage": "https://github.com/alchemy-run/cloudflare-bundler/tree/main/packages/cloudflare-bundler#readme",
  "bugs": {
    "url": "https://github.com/alchemy-run/cloudflare-bundler/issues"
  },
  "license": "MIT",
  "author": {
    "name": "John Royal",
    "email": "john@alchemy.run",
    "url": "https://distilled.cloud"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alchemy-run/cloudflare-bundler.git",
    "directory": "packages/cloudflare-bundler"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./rolldown": {
      "bun": "./src/rolldown/index.ts",
      "types": "./dist/rolldown/index.d.ts",
      "import": "./dist/rolldown/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "build:clean": "bun run ../../scripts/clean.ts && tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "bun run build:clean"
  },
  "dependencies": {
    "@cloudflare/unenv-preset": "^2.15.0",
    "glob-to-regexp": "^0.4.1",
    "unenv": "^2.0.0-rc.24",
    "unplugin": "^3.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/bun": "latest",
    "@types/glob-to-regexp": "^0.4.4",
    "@types/node": "^22.0.0",
    "miniflare": "^4.20260317.0",
    "rolldown": "^1.0.0-rc.9",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "catalog:",
    "rolldown": "^1.0.0-rc.9"
  },
  "peerDependenciesMeta": {
    "rolldown": {
      "optional": true
    }
  }
}
