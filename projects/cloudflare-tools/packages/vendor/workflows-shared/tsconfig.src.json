{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "compilerOptions": {
    "types": ["@cloudflare/workers-types/experimental", "@cloudflare/vitest-pool-workers/types"],
    "module": "Preserve",
    "moduleResolution": "bundler",
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": false,
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "isolatedDeclarations": false,
    "outDir": ".tsbuild/src",
    "rootDir": "src",
    "tsBuildInfoFile": ".tsbuild/src.tsbuildinfo"
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**/*.ts",
    "**/__tests__/**/*.tsx",
    "test/**",
    "tests/**"
  ]
}
