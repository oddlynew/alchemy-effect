{
  "extends": "@alchemy.run/typescript-config/bun.json",
  "include": ["src/node/**/*.ts", "src/index.ts"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": ".cache/tsconfig.node.tsbuildinfo",
    "outDir": ".cache/node",
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "module": "Preserve",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "references": [{ "path": "./tsconfig.shared.json" }]
}
