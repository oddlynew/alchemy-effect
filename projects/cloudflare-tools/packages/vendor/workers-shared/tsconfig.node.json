{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "include": ["src/node/**/*.ts", "src/index.ts"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": ".tsbuild/node.tsbuildinfo",
    "outDir": ".tsbuild/node",
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "module": "Preserve",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedDeclarations": false
  },
  "references": [
    {
      "path": "./tsconfig.shared.json"
    }
  ]
}
