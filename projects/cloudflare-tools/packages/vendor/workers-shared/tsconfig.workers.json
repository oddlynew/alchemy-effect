{
  "extends": "@alchemy.run/typescript-config/bun.json",
  "include": ["src/workers/**/*.ts"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": ".cache/tsconfig.workers.tsbuildinfo",
    "outDir": ".cache/workers",
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "module": "Preserve",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types/experimental", "@cloudflare/vitest-pool-workers/types"],
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true
  },
  "references": [{ "path": "./tsconfig.shared.json" }]
}
