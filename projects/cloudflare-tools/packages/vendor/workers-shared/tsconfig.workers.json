{
  "extends": "@oddlynew/alchemy-typescript-config/bun.json",
  "include": ["src/workers/**/*.ts"],
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": ".tsbuild/workers.tsbuildinfo",
    "outDir": ".tsbuild/workers",
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "module": "Preserve",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types/experimental", "@cloudflare/vitest-pool-workers/types"],
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "declaration": true,
    "declarationMap": true,
    "isolatedDeclarations": false
  },
  "references": [
    {
      "path": "./tsconfig.shared.json"
    }
  ]
}
