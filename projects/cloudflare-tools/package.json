{
  "name": "@distilled.cloud/cloudflare-bundler",
  "version": "0.0.2",
  "description": "Effect-native bundler for Cloudflare Workers.",
  "keywords": [
    "bundler",
    "cloudflare",
    "effect",
    "esbuild",
    "workers"
  ],
  "homepage": "https://github.com/alchemy-run/cloudflare-bundler#readme",
  "bugs": {
    "url": "https://github.com/alchemy-run/cloudflare-bundler/issues"
  },
  "license": "MIT",
  "author": {
    "name": "John Royal",
    "email": "john@alchemy.run",
    "url": "https://distilled.cloud"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alchemy-run/cloudflare-bundler.git"
  },
  "workspaces": {
    "catalog": {
      "esbuild": "^0.27.3"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./esbuild": {
      "bun": "./src/esbuild/index.ts",
      "types": "./dist/esbuild/index.d.ts",
      "import": "./dist/esbuild/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "rm -rf dist && tsc",
    "format": "oxfmt",
    "lint": "oxlint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "bun run scripts/typecheck.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@cloudflare/unenv-preset": "^2.15.0",
    "glob-to-regexp": "^0.4.1",
    "unenv": "^2.0.0-rc.24"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260310.1",
    "@effect/platform-node": "^4.0.0-beta.30",
    "@effect/vitest": "^4.0.0-beta.30",
    "@types/bun": "latest",
    "@types/glob-to-regexp": "^0.4.4",
    "miniflare": "^4.20260310.0",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.72.0"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.30",
    "esbuild": "catalog:",
    "typescript": "^5.9.3"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    }
  },
  "packageManager": "bun@1.3.9"
}
